FROM golang:1.26-alpine

WORKDIR /app

RUN apk add --no-cache git

# Install Air hot-reload
RUN go install github.com/air-verse/air@latest

COPY go.mod go.sum ./
RUN go mod download

# Source code is mounted as volume from docker-compose
# so we don't COPY it here — Air watches for changes and rebuilds

EXPOSE 7003

CMD ["air"]